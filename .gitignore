# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# local tooling artifacts (Grok / agent logs — not part of the site)
agent-tools/
mcps/
terminals/

# monti LiveKit agent local venv (Python; not Vercel)
monti-agent/.venv/

# local backups & scratch — not for the repo
_to_delete/
.fuse_hidden*
_debug_*.txt
_debug_*.html
*.stale
